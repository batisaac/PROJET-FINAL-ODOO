<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="action_report_inventaire" model="ir.actions.report">
        <field name="name">Inventaire du parc informatique</field>
        <field name="model">it.equipement</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">it_parc.report_inventaire_template</field>
        <field name="report_file">it_parc.report_inventaire_template</field>
        <field name="binding_model_id" ref="model_it_equipement"/>
        <field name="binding_type">report</field>
    </record>

    <template id="report_inventaire_template">
        <t t-call="web.html_container">
            <t t-call="web.external_layout">
                <div class="page">

                    <h2>Inventaire du Parc Informatique</h2>
                    <p class="text-muted">
                        Généré le : <t t-esc="context_timestamp(datetime.datetime.now()).strftime('%d/%m/%Y %H:%M')"/>
                        — Total : <t t-esc="len(docs)"/> équipement(s)
                    </p>

                    <!-- Filtres appliqués -->
                    <t t-set="departements" t-value="docs.mapped('department_id')"/>
                    <t t-set="categories" t-value="docs.mapped('categorie_id')"/>
                    <t t-if="departements or categories">
                        <p>
                            <t t-if="departements">
                                <strong>Département(s) : </strong>
                                <t t-esc="', '.join(departements.mapped('name'))"/>
                            </t>
                            <t t-if="departements and categories"> — </t>
                            <t t-if="categories">
                                <strong>Catégorie(s) : </strong>
                                <t t-esc="', '.join(categories.mapped('name'))"/>
                            </t>
                        </p>
                    </t>

                    <hr/>

                    <!-- Résumé par état -->
                    <div class="row mt-4">
                        <div class="col-3 text-center">
                            <h4><t t-esc="len(docs.filtered(lambda e: e.etat == 'brouillon'))"/></h4>
                            <small>Brouillon</small>
                        </div>
                        <div class="col-3 text-center">
                            <h4><t t-esc="len(docs.filtered(lambda e: e.etat == 'affecte'))"/></h4>
                            <small>Affectés</small>
                        </div>
                        <div class="col-3 text-center">
                            <h4><t t-esc="len(docs.filtered(lambda e: e.etat == 'maintenance'))"/></h4>
                            <small>En maintenance</small>
                        </div>
                        <div class="col-3 text-center">
                            <h4><t t-esc="len(docs.filtered(lambda e: e.etat == 'retire'))"/></h4>
                            <small>Retirés</small>
                        </div>
                    </div>

                    <hr/>

                    <!-- Regroupement par département -->
                    <t t-foreach="departements or [False]" t-as="dept">
                        <t t-if="dept">
                            <h4 class="mt-4"><t t-esc="dept.name"/></h4>
                        </t>
                        <t t-set="docs_dept" t-value="docs.filtered(lambda e: e.department_id == dept) if dept else docs"/>

                        <!-- Regroupement par catégorie dans le département -->
                        <t t-foreach="docs_dept.mapped('categorie_id')" t-as="cat">
                            <h5 class="mt-3 text-muted"><t t-esc="cat.name"/></h5>
                            <table class="table table-sm table-bordered">
                                <thead class="table-dark">
                                    <tr>
                                        <th>Référence</th>
                                        <th>Nom</th>
                                        <th>Marque / Modèle</th>
                                        <th>N° Série</th>
                                        <th>Employé</th>
                                        <th>Fin garantie</th>
                                        <th>État</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <t t-foreach="docs_dept.filtered(lambda e: e.categorie_id == cat)" t-as="doc">
                                        <tr>
                                            <td><t t-esc="doc.reference"/></td>
                                            <td><t t-esc="doc.nom"/></td>
                                            <td><t t-esc="(doc.marque or '') + ' ' + (doc.modele or '')"/></td>
                                            <td><t t-esc="doc.numero_serie"/></td>
                                            <td><t t-esc="doc.employe_id.name or '-'"/></td>
                                            <td><t t-esc="doc.date_fin_garantie or '-'"/></td>
                                            <td><t t-esc="doc.etat"/></td>
                                        </tr>
                                    </t>
                                </tbody>
                            </table>
                        </t>
                    </t>

                    <!-- Total valeur -->
                    <div class="row mt-4">
                        <div class="col-12 text-end">
                            <strong>Valeur totale du parc : </strong>
                            <t t-esc="sum(docs.mapped('valeur_achat'))"/> FCFA
                        </div>
                    </div>

                </div>
            </t>
        </t>
    </template>

</odoo>