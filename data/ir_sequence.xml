<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- Séquence pour les références d'équipements : EQ/2026/00001 -->
        <record id="seq_it_equipement" model="ir.sequence">
            <field name="name">Séquence Équipement IT</field>
            <field name="code">it.equipement</field>
            <field name="prefix">EQ/%(year)s/</field>
            <field name="padding">5</field>
            <field name="company_id" eval="False"/>
        </record>

        <!-- Séquence pour les références d'interventions : INT/2026/00001 -->
        <record id="seq_it_intervention" model="ir.sequence">
            <field name="name">Séquence Intervention IT</field>
            <field name="code">it.intervention</field>
            <field name="prefix">INT/%(year)s/</field>
            <field name="padding">5</field>
            <field name="company_id" eval="False"/>
        </record>

    </data>
</odoo>
